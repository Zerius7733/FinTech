OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=
NEWSAPI_KEY=
ALPHAVANTAGE_API_KEY=
MARKETAUX_API_KEY=
FMP_API_KEY=

NEWS_DEBUG=0
OPENAI_NEWS_MODEL=gpt-4.1-mini
OPENAI_NARRATIVE_MODEL=gpt-4.1-mini
GROQ_NARRATIVE_MODEL=llama-3.3-70b-versatile

OLLAMA_MODE=0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

INSIGHTS_PROVIDER=
INSIGHTS_RATE_LIMIT_ENABLED=1
INSIGHTS_RATE_LIMIT_WINDOW_SECONDS=3600
INSIGHTS_RATE_LIMIT_MAX_REQUESTS=10

ALLOWED_ORIGIN_REGEX=
ALLOWED_EXTENSION_ORIGIN_REGEX=chrome-extension://.*

AUTH_OTP_EXPIRY_MINUTES=10
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_ATTEMPTS=5

# Local development: print OTPs to the backend console instead of sending email.
#AUTH_EMAIL_MODE=console

# SMTP settings for real email delivery. Leave blank when AUTH_EMAIL_MODE=console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Unova
SMTP_USE_SSL=0
SMTP_USE_STARTTLS=1
